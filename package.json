{
  "name": "supercharger",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "node scripts/dev-launcher.js",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "dev:legacy": "concurrently -n server,web -c blue,green \"npm run dev -w server\" \"npm run dev -w web\"",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
