#!/bin/bash
export PGUSER=postgres PGDATABASE=support
for _ in $(seq 1 30); do pg_isready -q && break; sleep 1; done

RESULTS=""
add() {
  local sep=""; [ -n "$RESULTS" ] && sep=","
  if [ "$2" = "1" ]; then
    RESULTS="$RESULTS$sep{\"name\":\"$1\",\"pass\":true}"
  else
    RESULTS="$RESULTS$sep{\"name\":\"$1\",\"pass\":false,\"hint\":\"$3\"}"
  fi
}

check_task() { # file ref_query name hint
  local file="$1" ref="$2" name="$3" hint="$4"
  if [ ! -s "$file" ]; then
    add "$name" 0 "Save your query to $file."
    return
  fi
  local got want
  got=$(psql -tA -v ON_ERROR_STOP=1 -f "$file" 2>/dev/null)
  if [ $? -ne 0 ]; then
    add "$name" 0 "Your query in $file has a SQL error — run it in psql with \\\\i $file to see it."
    return
  fi
  want=$(psql -tA -c "$ref")
  if [ "$(echo "$got" | sort | md5sum)" = "$(echo "$want" | sort | md5sum)" ]; then
    add "$name" 1
  else
    add "$name" 0 "$hint"
  fi
}

check_task /work/task1.sql \
  "SELECT o.id, c.name, o.amount, o.status FROM orders o JOIN customers c ON c.id = o.customer_id" \
  "Task 1: orders with customer names" \
  "Expected columns: order id, customer name, amount, order status — one row per ORDER (inner join)."

check_task /work/task2.sql \
  "SELECT c.id, c.name FROM customers c LEFT JOIN orders o ON o.customer_id = c.id WHERE o.id IS NULL" \
  "Task 2: customers who never ordered" \
  "Anti-join pattern: LEFT JOIN orders, keep rows WHERE o.id IS NULL. Expected columns: id, name."

check_task /work/task3.sql \
  "SELECT c.name, o.amount FROM customers c LEFT JOIN orders o ON o.customer_id = c.id AND o.status = 'paid' WHERE c.status = 'active'" \
  "Task 3: active customers with paid orders (kept even with none)" \
  "The paid filter belongs in the ON clause, not WHERE — otherwise active customers without paid orders vanish. The customer-is-active filter stays in WHERE."

echo "{\"checkpoints\":[$RESULTS]}"
